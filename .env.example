# Backend
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:5173
FRONTEND_HOST=127.0.0.1
FRONTEND_PORT=5173
BACKEND_ORIGIN=http://127.0.0.1:8000

# DeepSeek / Qwen OpenAI-compatible LLM providers
LLM_ENABLED=false
LLM_DEFAULT_PROVIDER=deepseek
LLM_ALLOWED_PROVIDERS=deepseek,qwen
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=20
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# Prompt versions
PROMPT_DECISION_VERSION=v1.0
PROMPT_FOLLOWUP_DECISION_VERSION=v1.0
PROMPT_FINAL_REPLY_VERSION=v1.0

# Logging
LOG_DIR=../logs
LOG_LEVEL=INFO
LOG_MAX_BYTES=5242880
LOG_BACKUP_COUNT=5
AGENT_AUDIT_LOG_ENABLED=true

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=game_readonly
MYSQL_PASSWORD=
MYSQL_DATABASE=game_customer_service
MYSQL_ENABLED=false
MYSQL_PLAYERS_TABLE=players

# AMap MCP
AMAP_MCP_ENABLED=false
AMAP_MCP_URL=
AMAP_MCP_TIMEOUT_SECONDS=15

# Knowledge base
KNOWLEDGE_BASE_DIR=../knowledge_base
VECTOR_STORE_DIR=./data/vector_store
